{
  "name": "loe-col",
  "private": true,
  "version": "0.0.82",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "typecheck": "tsc --noEmit",
    "build": "npm run typecheck && vite build",
    "build:pages": "npm run typecheck && node tools/build_pages.mjs",
    "verify:pages-build": "node tools/verify_pages_build.mjs",
    "preview": "vite preview --host",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "release:pages-check": "npm run build:pages && npm run verify:pages-build"
  },
  "dependencies": {
    "phaser": "^3.90.0"
  },
  "devDependencies": {
    "@types/node": "^24.5.2",
    "playwright": "^1.59.1",
    "typescript": "^5.9.2",
    "vite": "^7.1.4"
  }
}
